[Unit]
Description=Picamera2 Camera Process (MJPEG server)
After=network.target

[Service]
User=hdtk7897
WorkingDirectory=/home/hdtk7897/manage_aquarium/aquarium_api
ExecStart=/usr/bin/env python3 /home/hdtk7897/manage_aquarium/aquarium_api/camera_process.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
